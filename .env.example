# Configuration FTP/SFTP pour le déploiement sur zer0day.io
# Copier ce fichier en .env et remplir les valeurs

# OVH - Serveur FTP (si timeout, passer à SFTP avec FTP_SFTP=true)
FTP_HOST=ftp.cluster130.hosting.ovh.net
FTP_USER=zerdayt
FTP_PASSWORD=votre_mot_de_passe_ftp
# Chemin vers le dossier anthropic dans la racine web (OVH: souvent www)
FTP_REMOTE_PATH=/home/zerdayt/www/anthropic/
FTP_PORT=21

# Utiliser SFTP au lieu de FTP (recommandé si FTP timeout)
# FTP_SFTP=true
# FTP_HOST=ssh.cluster130.hosting.ovh.net
# FTP_PORT=22
